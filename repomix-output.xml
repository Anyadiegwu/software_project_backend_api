    Report.countDocuments({ ...base, status: "in_progress" }),
    Report.countDocuments({ ...base, status: "resolved" }),
    Report.countDocuments({ ...base, status: "assigned" }),
  ]);
  res.json({ active, resolved, pending });
});

module.exports = router;
